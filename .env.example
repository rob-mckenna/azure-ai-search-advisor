# Microsoft Foundry configuration
AZURE_AI_FOUNDRY_ENDPOINT=https://your-project.services.ai.azure.com/
AZURE_AI_FOUNDRY_MODEL=gpt-4o

# Orchestration mode: "local" (direct service calls) or "framework" (Microsoft Agent Framework)
ORCHESTRATION_MODE=local

# Authentication (set to true for production)
AUTH_ENABLED=false
# Required when AUTH_ENABLED=true:
# AZURE_TENANT_ID=your-tenant-id
# AZURE_CLIENT_ID=your-app-client-id
# Authentication uses DefaultAzureCredential (az login, managed identity, etc.)
# Azure subscription for live service discovery (optional)
# AZURE_SUBSCRIPTION_ID=your-subscription-id

# CORS (comma-separated origins allowed to call the API)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging / observability
LOG_LEVEL=INFO
LOG_FORMAT=text
# Set LOG_FORMAT=json for production (Azure Monitor compatible)

# Rate limiting
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
